{
  "name": "prode-mundial-2026",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sync:participants": "tsx scripts/syncParticipantsFromCsv.ts",
    "sync:results": "tsx scripts/syncResultsFromCsv.ts",
    "predev": "npm run sync:participants && npm run sync:results",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite --host 127.0.0.1 --port 5175",
    "dev:server": "tsx server/index.ts",
    "server": "tsx server/index.ts",
    "prebuild": "npm run sync:participants && npm run sync:results",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "discover:league": "tsx scripts/discoverLeague.ts",
    "discover:sportmonks": "tsx scripts/discoverSportmonksWorldCup.ts",
    "discover:football-data": "tsx scripts/discoverFootballData.ts",
    "test": "vitest run",
    "validate:data": "tsx scripts/validateData.ts"
  },
  "dependencies": {
    "express": "^4.19.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vitest": "^4.0.16"
  }
}
